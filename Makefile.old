# =============================================================================
# Makefile for swiss-army-knife
# =============================================================================
# Usage examples:
#   make sdist                 # Regenerate changelog + build Hackage tarball
#   make upload-candidate      # Upload as Hackage candidate
#   make publish               # Publish release on Hackage (permanent)
#   make aur-prepare           # Update PKGBUILD + .SRCINFO and copy to ~/aur/swiss-army-knife
#   make clean                 # Clean build artifacts
# =============================================================================

PKG_NAME   := swiss-army-knife
CABAL_FILE := $(PKG_NAME).cabal

# Dynamically extract version from the .cabal file
VERSION := $(shell grep -m1 '^version:' $(CABAL_FILE) | cut -d: -f2 | tr -d ' \t')

TARBALL := dist-newstyle/sdist/$(PKG_NAME)-$(VERSION).tar.gz

# -----------------------------------------------------------------------------
# AUR configuration
# -----------------------------------------------------------------------------
AUR_DIR   ?= .
PKGBUILD  := $(AUR_DIR)/PKGBUILD
AUR_DEST  ?= /development/aur/swiss-army-knife

.PHONY: help changelog sdist upload-candidate publish clean version check \
        aur-update-pkgbuild aur-generate-srcinfo aur-prepare

# -----------------------------------------------------------------------------
help:
	@echo "Available targets:"
	@echo "  make sdist                 - Regenerate CHANGELOG.md and build Hackage tarball"
	@echo "  make upload-candidate      - Upload as Hackage candidate (safe for testing)"
	@echo "  make publish               - Publish release on Hackage (permanent!)"
	@echo "  make aur-prepare           - Update PKGBUILD + .SRCINFO and copy to $(AUR_DEST)"
	@echo "  make clean                 - Clean build artifacts and generated CHANGELOG.md"
	@echo "  make version               - Show detected package version"
	@echo "  make check                 - Run cabal check"

# -----------------------------------------------------------------------------
# Convert OrgMode changelog to GitHub-flavored Markdown (Hackage prefers this)
# -----------------------------------------------------------------------------
changelog:
	@echo "→ Converting CHANGELOG.org → CHANGELOG.md"
	pandoc CHANGELOG.org -o CHANGELOG.md -f org -t gfm --wrap=none

# -----------------------------------------------------------------------------
# Build source tarball (always regenerates changelog first)
# -----------------------------------------------------------------------------
sdist: changelog
	@echo "→ Building source tarball for version $(VERSION)"
	cabal clean
	cabal sdist
	@echo "→ Tarball ready: $(TARBALL)"

# -----------------------------------------------------------------------------
# Upload as candidate (for review on Hackage)
# -----------------------------------------------------------------------------
upload-candidate: sdist
	@echo "→ Uploading candidate $(PKG_NAME)-$(VERSION) to Hackage..."
	cabal upload $(TARBALL)
	@echo ""
	@echo "Review candidate at:"
	@echo "  https://hackage.haskell.org/package/$(PKG_NAME)-$(VERSION)/candidate"

# -----------------------------------------------------------------------------
# Publish the release (permanent - use with care)
# -----------------------------------------------------------------------------
publish: sdist
	@echo "→ Publishing $(PKG_NAME)-$(VERSION) to Hackage..."
	cabal upload --publish $(TARBALL)

# -----------------------------------------------------------------------------
# Run cabal check
# -----------------------------------------------------------------------------
check:
	cabal check

# -----------------------------------------------------------------------------
# Show detected version
# -----------------------------------------------------------------------------
version:
	@echo "$(PKG_NAME) version: $(VERSION)"

# -----------------------------------------------------------------------------
# Clean build artifacts + generated CHANGELOG.md
# -----------------------------------------------------------------------------
clean:
	cabal clean
	rm -f CHANGELOG.md

# =============================================================================
# AUR targets
# =============================================================================

# Update version and sha256sums in PKGBUILD from the fresh tarball
aur-update-pkgbuild: sdist
	@echo "→ Updating $(PKGBUILD) to version $(VERSION)"
	@if [ ! -f "$(PKGBUILD)" ]; then \
		echo "ERROR: $(PKGBUILD) not found. Set AUR_DIR=... if it's in another directory."; \
		exit 1; \
	fi
	@SHA256=$$(sha256sum $(TARBALL) | cut -d' ' -f1); \
	sed -i 's/^pkgver=.*/pkgver=$(VERSION)/' $(PKGBUILD); \
	sed -i 's/^pkgrel=.*/pkgrel=1/' $(PKGBUILD); \
	sed -i "s/^sha256sums=.*/sha256sums=('$$SHA256')/" $(PKGBUILD); \
	echo "→ PKGBUILD updated (pkgver=$(VERSION), sha256 updated)"

# Regenerate .SRCINFO (must be run from the directory containing PKGBUILD)
aur-generate-srcinfo:
	@echo "→ Regenerating .SRCINFO"
	@if [ ! -f "$(PKGBUILD)" ]; then \
		echo "ERROR: $(PKGBUILD) not found."; \
		exit 1; \
	fi
	cd $(AUR_DIR) && makepkg --printsrcinfo > .SRCINFO
	@echo "→ .SRCINFO regenerated"

# -----------------------------------------------------------------------------
# One-shot target: prepare everything needed for an AUR update
# This updates the local PKGBUILD, regenerates .SRCINFO, and copies both
# files to $(AUR_DEST) (default: ~/aur/swiss-army-knife)
# -----------------------------------------------------------------------------
aur-prepare: aur-update-pkgbuild aur-generate-srcinfo
	@echo "→ Copying updated files to $(AUR_DEST)"
	@mkdir -p $(AUR_DEST)
	@cp $(PKGBUILD) $(AUR_DEST)/
	@cp $(AUR_DIR)/.SRCINFO $(AUR_DEST)/.SRCINFO
	@echo ""
	@echo "✅ AUR files ready in $(AUR_DEST)"
	@echo "   Review, commit and push:"
	@echo "     cd $(AUR_DEST)"
	@echo "     git status"
	@echo "     git commit -am 'Update to $(VERSION)'"
	@echo "     git push"
