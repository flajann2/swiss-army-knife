{
  "name": "Sample Knife Document",
  "description": "sample knives to use with sak",
  "author": {
    "name": "Fred Mitchell",
    "email": "fred.mitchell@atomlogik.de"
  },
  "copyright": {
    "holder": "Atomlogik.de",
    "year": 2024
  },
  "knives": [
    {
      "knife": "ExtIP",
      "options": [
        {
          "option": null,
          "optype": "switch",
          "long": "nolocation",
          "short": "n",
          "help": "Don't display location information"
        },
        {
          "option": null,
          "optype": "switch",
          "long": "ipv6",
          "short": "i",
          "help": "Display the IPv6 address"
        }
      ],
      "action": [
        {
          "exe": {
            "bash": "ls\npwd\necho \"hello world\"\n",
            "unless": "nolocation | echo \"show location\"",
            "whens": [
              {
                "when": "ipv6 | echo \"show IPv6\"",
                "otherwise": "echo \"show IPv4\"\n"
              }
            ]
          }
        },
        {
          "exe": "echo \"The Grand Final\"\n"
        }
      ]
    },
    {
      "knife": "Kernel",
      "options": [
        {
          "option": null,
          "optype": "switch",
          "long": "justversion",
          "short": "j",
          "help": "Just display the numerical version number, no adjoining texet."
        }
      ],
      "action": {
        "exe": "echo \"some action and we are ignoring the switch for now\""
      }
    },
    {
      "knife": "Sleep",
      "options": [
        {
          "option": null,
          "optype": "parm",
          "long": "wait",
          "short": "w",
          "meta": "SECONDS",
          "parmtype": "Int",
          "help": "Seconds to wait before going to sleep"
        },
        {
          "option": null,
          "optype": "switch",
          "long": "shutdown",
          "short": "H",
          "help": "Shutdown the system, not sleep"
        }
      ],
      "action": {
        "whens": [
          {
            "when": "wait",
            "bash": "sleep ${SECONDS}\necho \"wait ${SECONDS} seconds then hibernate\"\n"
          },
          {
            "when": "shutdown",
            "bash": "echo \"halt\"\n"
          }
        ],
        "otherwise": {
          "bash": "echo \"hibernate\"\n"
        }
      }
    }
  ]
}
